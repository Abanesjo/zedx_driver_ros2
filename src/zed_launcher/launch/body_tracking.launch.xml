<launch>
  <arg name="camera_fps" default="60" />
  <arg name="fusion_publish_rate_hz" default="60.0" />

  <arg name="role" default="local" />
  <arg name="input_mode" default="stream" />
  <arg name="stream_address" default="$(env ZED_BOX_IP 127.0.0.1)" />
  <arg name="left_stream_port" default="30000" />
  <arg name="right_stream_port" default="30002" />
  <arg name="left_camera_name" default="zed_left" />
  <arg name="right_camera_name" default="zed_right" />
  <arg name="left_serial" default="41235597" />
  <arg name="right_serial" default="49967328" />
  <arg
    name="fusion_config_path"
    default="$(find-pkg-share zed_launcher)/calibration/calibration.json"
  />
  <!-- Options: HUMAN_BODY_FAST, HUMAN_BODY_MEDIUM, HUMAN_BODY_ACCURATE -->
  <arg name="body_model" default="HUMAN_BODY_ACCURATE" />
  <!-- Options: BODY_18, BODY_34, BODY_38 -->
  <arg name="body_format" default="BODY_38" />
  <arg name="confidence_threshold" default="70.0" />
  <arg name="single_body_enabled" default="true" />
  <arg name="single_body_switch_margin" default="10.0" />
  <arg name="single_body_switch_frames" default="5" />
  <arg name="publish_frame_id" default="fusion_world" />
  <arg name="output_topic" default="body_trk/skeletons" />
  <arg name="camera_resolution" default="HD1080" />
  <arg name="publish_images" default="false" />
  <arg name="publish_overlay_images" default="true" />
  <arg name="overlay_min_confidence" default="$(var confidence_threshold)" />
  <arg name="overlay_max_skeleton_age_sec" default="0.5" />
  <!-- Options: PERFORMANCE, QUALITY, ULTRA, NEURAL_LIGHT, NEURAL, NEURAL_PLUS -->
  <arg name="depth_mode" default="NEURAL_LIGHT" />
  <arg name="fusion_reference_frame" default="BASELINK" />
  <arg name="fusion_skeleton_smoothing" default="0.0" />
  <arg name="fusion_minimum_allowed_cameras" default="1" />
  <arg name="fusion_minimum_allowed_keypoints" default="7" />
  <arg name="sender_tracking_enabled" default="false" />
  <arg name="fusion_tracking_enabled" default="true" />
  <arg name="body_fitting_enabled" default="false" />
  <arg name="set_as_static" default="true" />
  <arg name="allow_reduced_precision_inference" default="false" />
  <arg name="sdk_gpu_id" default="-1" />
  <arg name="sdk_verbose" default="1" />
  <arg name="rviz" default="false" />
  <arg
    name="rviz_config"
    default="$(find-pkg-share zed_launcher)/rviz/body_fusion.rviz"
  />

  <node
    pkg="zed_launcher"
    exec="zed_body_fusion_node"
    namespace="zed_fusion"
    name="zed_body_fusion_node"
    output="screen"
  >
    <param name="role" value="$(var role)" />
    <param name="input_mode" value="$(var input_mode)" />
    <param name="stream_address" value="$(var stream_address)" />
    <param name="left_stream_port" value="$(var left_stream_port)" />
    <param name="right_stream_port" value="$(var right_stream_port)" />
    <param name="left_camera_name" value="$(var left_camera_name)" />
    <param name="right_camera_name" value="$(var right_camera_name)" />
    <param name="left_serial" value="$(var left_serial)" />
    <param name="right_serial" value="$(var right_serial)" />
    <param name="fusion_config_path" value="$(var fusion_config_path)" />
    <param name="body_model" value="$(var body_model)" />
    <param name="body_format" value="$(var body_format)" />
    <param name="confidence_threshold" value="$(var confidence_threshold)" />
    <param name="single_body_enabled" value="$(var single_body_enabled)" />
    <param name="single_body_switch_margin" value="$(var single_body_switch_margin)" />
    <param name="single_body_switch_frames" value="$(var single_body_switch_frames)" />
    <param name="publish_frame_id" value="$(var publish_frame_id)" />
    <param name="output_topic" value="$(var output_topic)" />
    <param name="camera_resolution" value="$(var camera_resolution)" />
    <param name="camera_fps" value="$(var camera_fps)" />
    <param name="publish_images" value="$(var publish_images)" />
    <param name="publish_overlay_images" value="$(var publish_overlay_images)" />
    <param name="overlay_min_confidence" value="$(var overlay_min_confidence)" />
    <param name="overlay_max_skeleton_age_sec" value="$(var overlay_max_skeleton_age_sec)" />
    <param name="depth_mode" value="$(var depth_mode)" />
    <param name="fusion_reference_frame" value="$(var fusion_reference_frame)" />
    <param name="fusion_publish_rate_hz" value="$(var fusion_publish_rate_hz)" />
    <param name="fusion_skeleton_smoothing" value="$(var fusion_skeleton_smoothing)" />
    <param name="fusion_minimum_allowed_cameras" value="$(var fusion_minimum_allowed_cameras)" />
    <param name="fusion_minimum_allowed_keypoints" value="$(var fusion_minimum_allowed_keypoints)" />
    <param name="sender_tracking_enabled" value="$(var sender_tracking_enabled)" />
    <param name="fusion_tracking_enabled" value="$(var fusion_tracking_enabled)" />
    <param name="body_fitting_enabled" value="$(var body_fitting_enabled)" />
    <param name="set_as_static" value="$(var set_as_static)" />
    <param
      name="allow_reduced_precision_inference"
      value="$(var allow_reduced_precision_inference)"
    />
    <param name="sdk_gpu_id" value="$(var sdk_gpu_id)" />
    <param name="sdk_verbose" value="$(var sdk_verbose)" />
  </node>

  <node
    if="$(var rviz)"
    pkg="rviz2"
    exec="rviz2"
    name="rviz2"
    output="screen"
    args="-d $(var rviz_config)"
  />
</launch>
