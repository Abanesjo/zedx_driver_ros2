<launch>
  <arg name="grab_frame_rate" default="60" />
  <arg name="stream_target_framerate" default="0" />

  <arg name="camera_model" default="$(env CAM_MODEL zedx)" />
  <arg name="left_camera_name" default="zed_left" />
  <arg name="right_camera_name" default="zed_right" />
  <arg name="left_camera_id" default="0" />
  <arg name="right_camera_id" default="1" />
  <arg name="left_stream_port" default="30000" />
  <arg name="right_stream_port" default="30002" />
  <arg name="stream_codec" default="H264" />
  <arg name="stream_bitrate" default="7000" />

  <include file="$(find-pkg-share zed_wrapper)/launch/zed_camera.launch.py">
    <arg name="camera_model" value="$(var camera_model)" />
    <arg name="camera_name" value="$(var left_camera_name)" />
    <arg name="camera_id" value="$(var left_camera_id)" />
    <arg name="publish_urdf" value="false" />
    <arg name="publish_tf" value="false" />
    <arg name="publish_map_tf" value="false" />
    <arg name="publish_imu_tf" value="false" />

    <arg
      name="param_overrides"
      value="stream_server.stream_enabled:=true;stream_server.codec:=$(var stream_codec);stream_server.port:=$(var left_stream_port);stream_server.bitrate:=$(var stream_bitrate);stream_server.target_framerate:=$(var stream_target_framerate);general.grab_resolution:=HD1080;general.grab_frame_rate:=$(var grab_frame_rate);general.publish_status:=false;video.publish_rgb:=false;video.publish_left_right:=false;video.publish_raw:=false;video.publish_gray:=false;video.publish_stereo:=false;sensors.publish_imu:=false;sensors.publish_imu_raw:=false;sensors.publish_cam_imu_transf:=false;sensors.publish_mag:=false;sensors.publish_baro:=false;sensors.publish_temp:=false;region_of_interest.publish_roi_mask:=false;depth.depth_mode:=NONE;depth.publish_depth_map:=false;depth.publish_depth_info:=false;depth.publish_point_cloud:=false;depth.publish_depth_confidence:=false;depth.publish_disparity:=false;pos_tracking.pos_tracking_enabled:=false;pos_tracking.publish_odom_pose:=false;pos_tracking.publish_pose_cov:=false;pos_tracking.publish_cam_path:=false;object_detection.od_enabled:=false;body_tracking.bt_enabled:=false;mapping.mapping_enabled:=false;mapping.publish_det_plane:=false"
    />
  </include>

  <include file="$(find-pkg-share zed_wrapper)/launch/zed_camera.launch.py">
    <arg name="camera_model" value="$(var camera_model)" />
    <arg name="camera_name" value="$(var right_camera_name)" />
    <arg name="camera_id" value="$(var right_camera_id)" />
    <arg name="publish_urdf" value="false" />
    <arg name="publish_tf" value="false" />
    <arg name="publish_map_tf" value="false" />
    <arg name="publish_imu_tf" value="false" />

    <arg
      name="param_overrides"
      value="stream_server.stream_enabled:=true;stream_server.codec:=$(var stream_codec);stream_server.port:=$(var right_stream_port);stream_server.bitrate:=$(var stream_bitrate);stream_server.target_framerate:=$(var stream_target_framerate);general.grab_resolution:=HD1080;general.grab_frame_rate:=$(var grab_frame_rate);general.publish_status:=false;video.publish_rgb:=false;video.publish_left_right:=false;video.publish_raw:=false;video.publish_gray:=false;video.publish_stereo:=false;sensors.publish_imu:=false;sensors.publish_imu_raw:=false;sensors.publish_cam_imu_transf:=false;sensors.publish_mag:=false;sensors.publish_baro:=false;sensors.publish_temp:=false;region_of_interest.publish_roi_mask:=false;depth.depth_mode:=NONE;depth.publish_depth_map:=false;depth.publish_depth_info:=false;depth.publish_point_cloud:=false;depth.publish_depth_confidence:=false;depth.publish_disparity:=false;pos_tracking.pos_tracking_enabled:=false;pos_tracking.publish_odom_pose:=false;pos_tracking.publish_pose_cov:=false;pos_tracking.publish_cam_path:=false;object_detection.od_enabled:=false;body_tracking.bt_enabled:=false;mapping.mapping_enabled:=false;mapping.publish_det_plane:=false"
    />
  </include>
</launch>
